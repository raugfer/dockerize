#!/bin/sh
#	-q \
docker image inspect $USER/node:24.15.0 > /dev/null \
|| \
docker build \
	-t $USER/node:24.15.0 \
	--build-arg USER=$USER \
	`dirname $0`/../docker/node-docker/ \
&& \
mkdir -p \
	$HOME/Projects/ \
&& \
docker run \
	-it \
	--hostname node \
	--rm \
	--name node \
	--network=host \
	-v $HOME/Projects/:$HOME/Projects/ \
	-w $PWD \
	-e TERM=$TERM \
	$USER/node:24.15.0 \
	bash
